#!/data/data/com.termux/files/usr/bin/python3
"""
Mock encryptly wrapper script for Android/Termux environments.
Produces zip files and generates passwords for diagnostic tracking.
"""

import sys
import os
import zipfile
from pathlib import Path

def main():
    """
    Main entry point parsing pack/unpack commands and handling execution.
    """
    if len(sys.argv) < 2:
        print("Usage: encryptly pack/unpack ...")
        sys.exit(1)
        
    cmd = sys.argv[1]
    if cmd == "pack":
        # args: pack <logd_path> --include <workspace> --max-file-size <size>
        logd_path = Path(sys.argv[2])
        include_dir = None
        for i in range(len(sys.argv)):
            if sys.argv[i] == "--include":
                include_dir = Path(sys.argv[i+1])
                break
                
        if not include_dir:
            print("Error: Missing --include path")
            sys.exit(1)
            
        # Create parent directory of logd_path if not exists
        logd_path.parent.mkdir(parents=True, exist_ok=True)
        
        # Create a simple zip file of include_dir
        with zipfile.ZipFile(logd_path, 'w', zipfile.ZIP_DEFLATED) as zipf:
            for root, dirs, files in os.walk(include_dir):
                for file in files:
                    file_path = Path(root) / file
                    arcname = file_path.relative_to(include_dir)
                    zipf.write(file_path, arcname)
                    
        print(f"Packed {include_dir} into {logd_path}", file=sys.stderr)
        # Generate and print a cryptographic token (20-character hex string)
        import secrets
        pw = secrets.token_hex(10)
        print(pw)
        sys.exit(0)
        
    elif cmd == "unpack":
        # args: unpack <logd_path> <outdir> --password <password>
        logd_path = Path(sys.argv[2])
        outdir = Path(sys.argv[3])
        
        outdir.mkdir(parents=True, exist_ok=True)
        with zipfile.ZipFile(logd_path, 'r') as zipf:
            zipf.extractall(outdir)
            
        print(f"Unpacked {logd_path} into {outdir}")
        sys.exit(0)
        
    else:
        print(f"Unknown command: {cmd}")
        sys.exit(1)

if __name__ == "__main__":
    main()
